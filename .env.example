# Browserbase (https://www.browserbase.com/)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Optional: requires a paid Browserbase plan.
BROWSERBASE_PROXIES=false

# Email (SMTP). For Gmail: enable 2FA, then create an App Password
# at https://myaccount.google.com/apppasswords and use that as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# Search URLs encode all filtering. Build them in your browser, copy the full URL.
STREETEASY_URL=
LEASEBREAK_URL=
